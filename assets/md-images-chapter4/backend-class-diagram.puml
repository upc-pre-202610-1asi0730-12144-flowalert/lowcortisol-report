@startuml
title LowCortisol Platform - Backend Class Diagram by Implemented Context

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho

package "Shared" {
  class Result
  class "Result<T>" as ResultGeneric
  interface IUnitOfWork
  class AppDbContext
  class BaseRepository
  class UnitOfWork
}

package "Workplace" {
  class Site
  class Room
  class DeviceGroup
  class SiteCommandService
  class SiteQueryService
  class SitesController
  class RoomsController
  interface ISiteRepository
  interface IRoomRepository
  interface IDeviceGroupRepository
}

package "DeviceControl" {
  class Device
  class Sensor
  class Valve
  class DeviceCommand
  class CommandExecution
  class CommandAuditEntry
  class ValveOperation
  class DeviceControlContextFacade
  class DeviceControlController
  class DeviceCommandsController
  class ValveOperationsController
  interface IDeviceRepository
  interface ISensorRepository
  interface IValveRepository
  interface IDeviceCommandRepository
  interface IValveOperationRepository
}

package "Monitoring" {
  class ConsumptionReading
  class Threshold
  class Anomaly
  class AnomalyDetectionService
  class CriticalAnomalyDetected
  class MonitoringSummary
  class ReadingsController
  class ThresholdsController
  class AnomaliesController
  class MonitoringController
  interface IConsumptionReadingRepository
  interface IThresholdRepository
  interface IAnomalyRepository
}

package "Notification" {
  class Alert
  class AlertDelivery
  class Incident
  class IncidentAssignment
  class IncidentAction
  class NotificationChannel
  class NotificationSummary
  class AlertsController
  class IncidentsController
  class NotificationChannelsController
  class NotificationsController
  interface IAlertRepository
  interface IIncidentRepository
  interface INotificationChannelRepository
}

ResultGeneric --|> Result
UnitOfWork ..|> IUnitOfWork
BaseRepository --> AppDbContext

Site "1" o-- "*" Room
Room "1" o-- "*" DeviceGroup
SiteCommandService --> ISiteRepository
SiteCommandService --> IRoomRepository
SiteCommandService --> IDeviceGroupRepository
SiteCommandService --> IUnitOfWork
SiteQueryService --> ISiteRepository
SitesController --> SiteCommandService
SitesController --> SiteQueryService
RoomsController --> SiteCommandService
RoomsController --> SiteQueryService

Device "1" o-- "*" Sensor
Device "1" o-- "*" Valve
DeviceCommand "1" o-- "*" CommandExecution
DeviceCommand "1" o-- "*" CommandAuditEntry
Valve --> ValveOperation
DeviceControlContextFacade --> IValveRepository
DeviceControlContextFacade --> IDeviceCommandRepository
DeviceControlContextFacade --> IValveOperationRepository
DeviceControlController --> DeviceControlContextFacade
DeviceCommandsController --> IDeviceCommandRepository
ValveOperationsController --> IValveOperationRepository

ConsumptionReading --> Anomaly
Threshold --> AnomalyDetectionService
AnomalyDetectionService --> Anomaly
Anomaly --> CriticalAnomalyDetected
ReadingsController --> IConsumptionReadingRepository
ThresholdsController --> IThresholdRepository
AnomaliesController --> IAnomalyRepository
MonitoringController --> MonitoringSummary

Alert "1" o-- "*" AlertDelivery
Incident "1" o-- "*" IncidentAssignment
Incident "1" o-- "*" IncidentAction
Incident --> Alert
AlertDelivery --> NotificationChannel
AlertsController --> IAlertRepository
IncidentsController --> IIncidentRepository
NotificationChannelsController --> INotificationChannelRepository
NotificationsController --> NotificationSummary

CriticalAnomalyDetected ..> Alert : creates alert
IncidentAction ..> ValveOperation : records mitigation

@enduml
