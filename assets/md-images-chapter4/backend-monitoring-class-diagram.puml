@startuml
title LowCortisol Platform - Monitoring Backend Class Diagram

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho

package "Domain" {
  class ConsumptionReading
  class Threshold
  class Anomaly
  class AnomalyDetectionService
  class AnomalyDetectionResult
  class CriticalAnomalyDetected
  class MonitoringSummary

  class RegisterConsumptionReadingCommand
  class CreateThresholdCommand
  class ResolveAnomalyCommand
  class GetRecentReadingsQuery
  class GetActiveThresholdsQuery
  class GetOpenAnomaliesQuery
  class GetMonitoringSummaryQuery

  interface IConsumptionReadingRepository
  interface IThresholdRepository
  interface IAnomalyRepository
}

package "Application" {
  class RegisterConsumptionReadingResult
  interface IConsumptionReadingCommandService
  interface IConsumptionReadingQueryService
  interface IThresholdCommandService
  interface IThresholdQueryService
  interface IAnomalyCommandService
  interface IAnomalyQueryService
  interface IMonitoringSummaryQueryService
}

package "Infrastructure" {
  class EfConsumptionReadingRepository
  class EfThresholdRepository
  class EfAnomalyRepository
  class InMemoryConsumptionReadingRepository
  class InMemoryThresholdRepository
  class InMemoryAnomalyRepository
}

package "Interfaces / REST" {
  class ReadingsController
  class ThresholdsController
  class AnomaliesController
  class MonitoringController
  class RegisterConsumptionReadingResource
  class RegisterConsumptionReadingResultResource
  class ConsumptionReadingResource
  class CreateThresholdResource
  class ThresholdResource
  class AnomalyResource
  class MonitoringSummaryResource
}

ConsumptionReading --> Anomaly
Threshold --> AnomalyDetectionService
AnomalyDetectionService --> AnomalyDetectionResult
AnomalyDetectionResult --> Anomaly
Anomaly --> CriticalAnomalyDetected

IConsumptionReadingRepository <|.. EfConsumptionReadingRepository
IThresholdRepository <|.. EfThresholdRepository
IAnomalyRepository <|.. EfAnomalyRepository
IConsumptionReadingRepository <|.. InMemoryConsumptionReadingRepository
IThresholdRepository <|.. InMemoryThresholdRepository
IAnomalyRepository <|.. InMemoryAnomalyRepository

IConsumptionReadingCommandService --> IConsumptionReadingRepository
IConsumptionReadingCommandService --> IThresholdRepository
IConsumptionReadingCommandService --> IAnomalyRepository
IConsumptionReadingCommandService --> AnomalyDetectionService
IThresholdCommandService --> IThresholdRepository
IAnomalyCommandService --> IAnomalyRepository
IMonitoringSummaryQueryService --> MonitoringSummary

ReadingsController --> IConsumptionReadingCommandService
ReadingsController --> IConsumptionReadingQueryService
ThresholdsController --> IThresholdCommandService
ThresholdsController --> IThresholdQueryService
AnomaliesController --> IAnomalyCommandService
AnomaliesController --> IAnomalyQueryService
MonitoringController --> IMonitoringSummaryQueryService

ReadingsController ..> RegisterConsumptionReadingResource
ThresholdsController ..> CreateThresholdResource
MonitoringController ..> MonitoringSummaryResource

@enduml
