@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 135
skinparam maxMessageSize 70
skinparam nodesep 35
skinparam ranksep 45
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 165
  Padding 8
}
hide stereotype
top to bottom direction

title LowCortisol - C4 Context Diagram

rectangle "<b>Owner / Manager</b>\n<i>[Person]</i>\n\nCreates sites, reviews consumption, manages plans, reports and support requests." as Owner #0B5593
rectangle "<b>Site Operator</b>\n<i>[Person]</i>\n\nMonitors readings, operates valves, reviews alerts and handles incidents." as Operator #0B5593
rectangle "<b>Support Agent</b>\n<i>[Person]</i>\n\nReviews tickets and helps users with operational problems." as SupportAgent #0B5593

rectangle "<b>LowCortisol Platform</b>\n<i>[Software System]</i>\n\nWater and gas monitoring platform for sites, sensors, valves, conduits, alerts, incidents and reports." as LowCortisol #0B6FB3

rectangle "<b>Render</b>\n<i>[External Platform]</i>\n\nHosts the Vue WebApp and ASP.NET Core API." as Render #7F8C8D
rectangle "<b>PostgreSQL Service</b>\n<i>[External Database Service]</i>\n\nStores operational data for the deployed backend." as Postgres #7F8C8D
rectangle "<b>OpenStreetMap</b>\n<i>[External Map Service]</i>\n\nProvides map interaction for selecting site locations." as Maps #7F8C8D
rectangle "<b>Email Provider</b>\n<i>[Future External System]</i>\n\nProjected delivery channel for password, alert and support emails." as Email #7F8C8D
rectangle "<b>Payment Provider</b>\n<i>[Future External System]</i>\n\nProjected provider for subscription checkout and payment validation." as Payment #7F8C8D
rectangle "<b>IoT Device Network</b>\n<i>[Future / Physical System]</i>\n\nSensors, valves and hubs that can provide readings and receive commands." as Iot #7F8C8D

Owner --> LowCortisol : manages platform\n[Browser]
Operator --> LowCortisol : operates monitoring flows\n[Browser]
SupportAgent --> LowCortisol : handles support flow\n[Browser]

LowCortisol --> Render : deployed on\n[Docker / Web Service]
LowCortisol --> Postgres : persists data\n[EF Core / SQL]
LowCortisol --> Maps : selects location\n[HTTPS]
LowCortisol --> Email : sends messages\n[future]
LowCortisol --> Payment : validates payments\n[future]
LowCortisol --> Iot : reads and commands devices\n[future / adapter]

Owner -[hidden]right- Operator
Operator -[hidden]right- SupportAgent
Render -[hidden]right- Postgres
Postgres -[hidden]right- Maps
Maps -[hidden]right- Email
Email -[hidden]right- Payment
Payment -[hidden]right- Iot

legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> software system |
  |<#7F8C8D> external system |
endlegend

@enduml
