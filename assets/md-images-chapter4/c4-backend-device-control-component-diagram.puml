@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 130
skinparam nodesep 35
skinparam ranksep 40
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 160
  Padding 8
}
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
left to right direction

title LowCortisol - DeviceControl Backend Component Diagram

rectangle "<b>Browser SPA</b>\n<i>[Vue 3 + Vite]</i>\n\nUses device, command and valve operation endpoints." as Spa #3498DB
database "<b>lowcortisol_db</b>\n<i>[PostgreSQL]</i>\n\nStores devices, sensors, valves, commands and valve operations." as Db
rectangle "<b>Notification Context</b>\n<i>[Consumer]</i>\n\nRequests incident mitigation by closing a valve." as Notification #7F8C8D

rectangle "<b>DeviceControlController</b>\n<i>[REST Controller]</i>\n\nExposes mitigation summary and incident valve close result." as ControlController #0B6FB3
rectangle "<b>DeviceCommandsController</b>\n<i>[REST Controller]</i>\n\nLists and exposes device command history." as CommandController #0B6FB3
rectangle "<b>ValveOperationsController</b>\n<i>[REST Controller]</i>\n\nLists valve operations by valve or incident." as OperationController #0B6FB3
rectangle "<b>Resources + Assemblers</b>\n<i>[Interfaces]</i>\n\nDeviceCommand, CommandExecution, CommandAuditEntry, ValveOperation and Mitigation resources." as Resources #0B6FB3
rectangle "<b>Command Services</b>\n<i>[Application]</i>\n\nOpenValve, ExecuteDeviceCommand, CloseValveForIncident and CancelDeviceCommand." as CommandServices #3498DB
rectangle "<b>Query Services</b>\n<i>[Application]</i>\n\nDevice command, valve operation and mitigation summary queries." as QueryServices #3498DB
rectangle "<b>Device + Sensor + Valve</b>\n<i>[Domain]</i>\n\nPhysical device model and valve state rules." as PhysicalModel #27AE60
rectangle "<b>DeviceCommand</b>\n<i>[Domain Aggregate]</i>\n\nCommand status, source, execution and audit trail." as DeviceCommand #27AE60
rectangle "<b>ValveOperation</b>\n<i>[Domain Entity]</i>\n\nOperational record for opening, closing or incident mitigation." as ValveOperation #27AE60
rectangle "<b>Repository Ports</b>\n<i>[Domain Contracts]</i>\n\nIDeviceRepository, ISensorRepository, IValveRepository, ICommandRepository, IValveOperationRepository." as Ports #27AE60
rectangle "<b>EF + InMemory Repositories</b>\n<i>[Infrastructure]</i>\n\nPostgreSQL adapter and fallback demo repositories." as Repositories #7F8C8D

Spa --> ControlController : REST / JSON
Spa --> CommandController : REST / JSON
Spa --> OperationController : REST / JSON
Notification --> CommandServices : close valve for incident
ControlController --> Resources : maps resources
CommandController --> Resources : maps resources
OperationController --> Resources : maps resources
ControlController --> CommandServices : commands
CommandController --> QueryServices : queries
OperationController --> QueryServices : queries
CommandServices --> PhysicalModel : applies valve rules
CommandServices --> DeviceCommand : creates command
CommandServices --> ValveOperation : records operation
QueryServices --> Ports : reads model
CommandServices --> Ports : persists model
Ports --> Repositories : implemented by
Repositories --> Db : EF Core / SQL

@enduml
