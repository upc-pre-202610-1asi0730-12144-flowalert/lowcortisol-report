@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 130
skinparam nodesep 35
skinparam ranksep 40
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 160
  Padding 8
}
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
left to right direction

title LowCortisol - Workplace Backend Component Diagram

rectangle "<b>Browser SPA</b>\n<i>[Vue 3 + Vite]</i>\n\nUses Workplace endpoints." as Spa #3498DB
database "<b>lowcortisol_db</b>\n<i>[PostgreSQL]</i>\n\nStores sites, rooms and device groups." as Db
rectangle "<b>DeviceControl Context</b>\n<i>[ACL Provider]</i>\n\nProvides physical inventory for site physical model." as DeviceControl #7F8C8D

rectangle "<b>SitesController</b>\n<i>[REST Controller]</i>\n\nGET sites, GET site, GET physical model, POST site." as SitesController #0B6FB3
rectangle "<b>RoomsController</b>\n<i>[REST Controller]</i>\n\nPOST rooms, GET rooms, POST device groups, GET device groups." as RoomsController #0B6FB3
rectangle "<b>Resources + Assemblers</b>\n<i>[Interfaces]</i>\n\nCreateSiteResource, SiteResource, RoomResource, DeviceGroupResource, PhysicalModelResource." as Resources #0B6FB3
rectangle "<b>SiteCommandService</b>\n<i>[Application]</i>\n\nHandles CreateSite, CreateRoom and CreateDeviceGroup commands." as CommandService #3498DB
rectangle "<b>SiteQueryService</b>\n<i>[Application]</i>\n\nHandles site list, site detail, rooms, device groups and physical model queries." as QueryService #3498DB
rectangle "<b>Site Aggregate</b>\n<i>[Domain]</i>\n\nOwns site data and coordinates room/group creation." as Site #27AE60
rectangle "<b>Room + DeviceGroup</b>\n<i>[Domain Entities]</i>\n\nRepresent physical organization by room and group." as Entities #27AE60
rectangle "<b>Repository Ports</b>\n<i>[Domain Contracts]</i>\n\nISiteRepository, IRoomRepository, IDeviceGroupRepository." as Ports #27AE60
rectangle "<b>EF + InMemory Repositories</b>\n<i>[Infrastructure]</i>\n\nReal PostgreSQL adapter plus demo fallback." as Repositories #7F8C8D

Spa --> SitesController : REST / JSON
Spa --> RoomsController : REST / JSON
SitesController --> Resources : maps resources
RoomsController --> Resources : maps resources
SitesController --> CommandService : commands
RoomsController --> CommandService : commands
SitesController --> QueryService : queries
RoomsController --> QueryService : queries
CommandService --> Site : applies rules
CommandService --> Entities : creates children
QueryService --> Ports : reads model
CommandService --> Ports : persists model
Ports --> Repositories : implemented by
Repositories --> Db : EF Core / SQL
QueryService --> DeviceControl : physical inventory ACL

@enduml
