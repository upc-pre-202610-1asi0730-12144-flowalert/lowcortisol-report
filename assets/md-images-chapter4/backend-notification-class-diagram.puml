@startuml
title LowCortisol Platform - Notification Backend Class Diagram

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho

package "Domain" {
  class Alert
  class AlertDelivery
  class Incident
  class IncidentAssignment
  class IncidentAction
  class NotificationChannel
  class NotificationSummary
  class NotificationRiskResponseResult

  class CreateAlertFromCriticalAnomalyCommand
  class CreateIncidentFromAlertCommand
  class RequestIncidentMitigationCommand
  class AssignIncidentCommand
  class RegisterIncidentActionCommand
  class ResolveIncidentCommand
  class CloseIncidentCommand

  interface IAlertRepository
  interface IIncidentRepository
  interface INotificationChannelRepository
}

package "Application" {
  interface IAlertCommandService
  interface IAlertQueryService
  interface IIncidentCommandService
  interface IIncidentMitigationCommandService
  interface IIncidentQueryService
  interface INotificationChannelCommandService
  interface INotificationChannelQueryService
  interface INotificationSummaryQueryService
}

package "Infrastructure" {
  class EfAlertRepository
  class EfIncidentRepository
  class EfNotificationChannelRepository
  class InMemoryAlertRepository
  class InMemoryIncidentRepository
  class InMemoryNotificationChannelRepository
}

package "Interfaces / REST" {
  class AlertsController
  class IncidentsController
  class NotificationChannelsController
  class NotificationsController
  class AlertResource
  class AlertDeliveryResource
  class IncidentResource
  class IncidentActionResource
  class IncidentAssignmentResource
  class NotificationChannelResource
  class NotificationSummaryResource
}

Alert "1" o-- "*" AlertDelivery
Incident "1" o-- "*" IncidentAssignment
Incident "1" o-- "*" IncidentAction
Incident --> Alert
AlertDelivery --> NotificationChannel

IAlertRepository <|.. EfAlertRepository
IIncidentRepository <|.. EfIncidentRepository
INotificationChannelRepository <|.. EfNotificationChannelRepository
IAlertRepository <|.. InMemoryAlertRepository
IIncidentRepository <|.. InMemoryIncidentRepository
INotificationChannelRepository <|.. InMemoryNotificationChannelRepository

IAlertCommandService --> IAlertRepository
IIncidentCommandService --> IIncidentRepository
IIncidentMitigationCommandService --> IIncidentRepository
IIncidentMitigationCommandService --> IncidentAction
INotificationChannelCommandService --> INotificationChannelRepository
INotificationSummaryQueryService --> NotificationSummary

AlertsController --> IAlertCommandService
AlertsController --> IAlertQueryService
IncidentsController --> IIncidentCommandService
IncidentsController --> IIncidentMitigationCommandService
IncidentsController --> IIncidentQueryService
NotificationChannelsController --> INotificationChannelCommandService
NotificationChannelsController --> INotificationChannelQueryService
NotificationsController --> INotificationSummaryQueryService

AlertsController ..> CreateAlertFromCriticalAnomalyCommand
IncidentsController ..> CreateIncidentFromAlertCommand
IncidentsController ..> RequestIncidentMitigationCommand
IncidentsController ..> RegisterIncidentActionCommand
NotificationsController ..> NotificationSummaryResource

@enduml
