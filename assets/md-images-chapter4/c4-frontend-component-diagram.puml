@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 135
skinparam maxMessageSize 70
skinparam nodesep 35
skinparam ranksep 45
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 165
  Padding 8
}
skinparam rectangle<<SystemBoundary>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  Padding 12
}
hide stereotype
left to right direction

title LowCortisol - Frontend General Component Diagram

rectangle "<b>Browser SPA</b>\n<i>[Vue 3 + Vite]</i>\n\nClient-side application delivered to the browser." as Spa #3498DB
rectangle "<b>Platform API</b>\n<i>[ASP.NET Core Web API]</i>\n\nReal backend for Workplace, DeviceControl, Monitoring and Notification." as Api #0B6FB3
rectangle "<b>i18n JSON Files</b>\n<i>[Public Assets]</i>\n\nSpanish, English and Portuguese copy resources." as I18n #7F8C8D
rectangle "<b>Local Platform Data</b>\n<i>[Fallback Store]</i>\n\nCentralized local fallback used when backend modules are unavailable." as LocalData #7F8C8D

rectangle "<b>Frontend Source App</b>\n<i>[src/app]</i>" <<SystemBoundary>> {
  rectangle "<b>Router</b>\n<i>[Vue Router]</i>\n\nPublic routes, protected routes and navigation guards." as Router #3498DB
  rectangle "<b>IAM</b>\n<i>[Frontend Module]</i>\n\nLogin, register, recovery, profile and session screens." as Iam #3498DB
  rectangle "<b>Plan</b>\n<i>[Frontend Module]</i>\n\nPlan cards, checkout flow, subscription limits and service requests." as Plan #3498DB
  rectangle "<b>Workplace</b>\n<i>[Frontend Module]</i>\n\nSites, rooms, groups, map selection and physical model views." as Workplace #3498DB
  rectangle "<b>DeviceControl</b>\n<i>[Frontend Module]</i>\n\nDevices, sensors, valves, conduits and command history." as DeviceControl #3498DB
  rectangle "<b>Monitoring</b>\n<i>[Frontend Module]</i>\n\nDashboard, readings, thresholds, anomalies and reports." as Monitoring #3498DB
  rectangle "<b>Notification</b>\n<i>[Frontend Module]</i>\n\nAlerts, incidents, channels and mitigation actions." as Notification #3498DB
  rectangle "<b>Support</b>\n<i>[Frontend Module]</i>\n\nTickets, agents and help articles." as Support #3498DB
  rectangle "<b>Shared</b>\n<i>[Reusable UI + Services]</i>\n\nLayout, bottom navigation, side panel, cards, badges, modals, selects, date range, API client and preferences." as Shared #7F8C8D
}

Spa --> Router : uses
Router --> Iam : routes
Router --> Plan : routes
Router --> Workplace : routes
Router --> DeviceControl : routes
Router --> Monitoring : routes
Router --> Notification : routes
Router --> Support : routes

Iam --> Shared : uses
Plan --> Shared : uses
Workplace --> Shared : uses
DeviceControl --> Shared : uses
Monitoring --> Shared : uses
Notification --> Shared : uses
Support --> Shared : uses

Workplace --> Api : real REST endpoints
DeviceControl --> Api : real REST endpoints
Monitoring --> Api : real REST endpoints
Notification --> Api : real REST endpoints
Iam --> LocalData : frontend/local flow
Plan --> LocalData : frontend/local flow
Support --> LocalData : frontend/local flow
Shared --> I18n : loads translations

legend right
  <b>Frontend reality</b>
  |<#3498DB> frontend module |
  |<#0B6FB3> real backend API |
  |<#7F8C8D> shared/fallback asset |
endlegend

@enduml
