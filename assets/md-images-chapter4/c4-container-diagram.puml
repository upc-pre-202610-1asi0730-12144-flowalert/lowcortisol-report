@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 135
skinparam maxMessageSize 70
skinparam nodesep 35
skinparam ranksep 45
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 165
  Padding 8
}
skinparam database {
  MinimumWidth 165
  Padding 8
}
skinparam rectangle<<SystemBoundary>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  MinimumWidth 700
  Padding 12
}
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
skinparam databaseFontStyle plain
hide stereotype
left to right direction

title LowCortisol - C4 Container Diagram

rectangle "<b>LowCortisol User</b>\n<i>[Person]</i>\n\nUses public and authenticated flows." as User #0B5593

rectangle "<b>LowCortisol Product Boundary</b>\n<i>[Software System]</i>" <<SystemBoundary>> {
  rectangle "<b>Landing Website</b>\n<i>[Static Website]</i>\n\nPublic value proposition and call-to-action to the WebApp." as Website #3498DB
  rectangle "<b>LowCortisol WebApp</b>\n<i>[Vue 3 + Vite]</i>\n\nSource project with routes, pages, stores, facades and API services." as WebApp #3498DB
  rectangle "<b>Browser SPA</b>\n<i>[Vue Router + JavaScript]</i>\n\nRuntime application loaded in the user's browser." as Spa #3498DB
  rectangle "<b>Platform API</b>\n<i>[ASP.NET Core Web API]</i>\n\nModular monolith with Workplace, DeviceControl, Monitoring and Notification contexts." as Api #3498DB
  database "<b>lowcortisol_db</b>\n<i>[PostgreSQL]</i>\n\nPersists sites, rooms, groups, devices, readings, thresholds, anomalies, alerts, incidents and operations." as Db
}

rectangle "<b>Render</b>\n<i>[Cloud Platform]</i>\n\nHosts website, WebApp and Platform API." as Render #7F8C8D
rectangle "<b>OpenStreetMap</b>\n<i>[Map Provider]</i>\n\nSupports site location selection." as Maps #7F8C8D
rectangle "<b>Email Provider</b>\n<i>[Future Integration]</i>\n\nProjected channel for messages and alerts." as Email #7F8C8D
rectangle "<b>Payment Provider</b>\n<i>[Future Integration]</i>\n\nProjected subscription checkout integration." as Payment #7F8C8D
rectangle "<b>IoT Device Network</b>\n<i>[Future / Physical Integration]</i>\n\nProjected source of sensor readings and valve commands." as Iot #7F8C8D

User --> Website : browses\n[HTTPS]
Website --> WebApp : opens app\n[CTA]
User --> WebApp : uses directly\n[HTTPS]
WebApp --> Spa : builds into\n[Vite build]
Spa --> Api : consumes REST API\n[HTTPS / JSON]
Api --> Db : reads and writes\n[EF Core / Npgsql]

Website --> Render : hosted on
WebApp --> Render : deployed on
Api --> Render : deployed on
Spa --> Maps : map tiles and geocoding\n[HTTPS]
Api --> Email : sends messages\n[future]
Api --> Payment : payment status\n[future]
Api --> Iot : readings and commands\n[future adapter]

Website -[hidden]down- WebApp
WebApp -[hidden]down- Spa
Spa -[hidden]right- Api
Api -[hidden]right- Db

legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#3498DB> container |
  |<#C9332B> database |
  |<#7F8C8D> external container |
endlegend

@enduml
