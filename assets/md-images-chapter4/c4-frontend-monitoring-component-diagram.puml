@startuml
title LowCortisol Platform - Monitoring Frontend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Provides monitoring dashboard, real-time consumption view and reports UI.")
Container(api, "Backend API", "ASP.NET Core Web API", "Provides readings, thresholds, anomalies and monitoring summary endpoints.")

Container_Boundary(monitoring, "Monitoring") {

  Component(presentation, "Presentation", "Vue Screens / Components", "Contains dashboard screen, report screen, metric cards, real-time chart, reading sections and anomaly sections.")

  Component(application, "Application", "Pinia Store / Facade", "Coordinates dashboard loading, reading generation, threshold loading, anomaly loading and report generation UI.")

  Component(domain, "Domain", "Domain Model", "Contains ConsumptionReading, Threshold, Anomaly, MonitoringSummary and ConsumptionReport frontend concepts.")

  Component(infrastructure, "Infrastructure", "API Service", "Consumes monitoring backend endpoints and adapts responses to frontend models.")
}

Rel(spa, presentation, "Uses monitoring screens", "Vue Router")

Rel(presentation, application, "Dispatches monitoring actions")
Rel(application, domain, "Uses monitoring models")
Rel(application, infrastructure, "Delegates API operations")

Rel(infrastructure, api, "Consumes monitoring endpoints", "HTTPS/JSON")

@enduml
