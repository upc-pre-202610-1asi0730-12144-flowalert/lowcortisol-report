@startuml
title LowCortisol Platform - Workplace Frontend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Provides site, room, group and physical model management.")
Container(api, "Backend API", "ASP.NET Core Web API", "Provides Workplace endpoints for sites, rooms, device groups and physical model.")

Container_Boundary(workspace, "Workplace") {

  Component(presentation, "Presentation", "Vue Screens / Components", "Contains sites screen, site list, site detail, map selection, physical model and group inventory.")

  Component(application, "Application", "Pinia Store / Facade", "Coordinates site loading, site creation, room creation, group creation and physical model loading.")

  Component(domain, "Domain", "Domain Model", "Contains Site, Room, DeviceGroup and physical inventory frontend concepts.")

  Component(infrastructure, "Infrastructure", "API Service", "Consumes Workplace backend endpoints and adapts responses to frontend models.")
}

Rel(spa, presentation, "Uses workplace screens", "Vue Router")

Rel(presentation, application, "Dispatches workplace actions")
Rel(application, domain, "Uses workplace models")
Rel(application, infrastructure, "Delegates API operations")

Rel(infrastructure, api, "Consumes Workplace endpoints", "HTTPS/JSON")

@enduml
