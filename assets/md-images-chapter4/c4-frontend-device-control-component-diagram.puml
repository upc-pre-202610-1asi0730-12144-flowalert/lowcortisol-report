@startuml
title LowCortisol Platform - Device Control Frontend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Provides device control management.")
Container(api, "Backend API", "ASP.NET Core Web API", "Provides DeviceControl endpoints for commands, valve operations and mitigation.")

Container_Boundary(deviceControl, "Device Control") {

  Component(presentation, "Presentation", "Vue Screens / Components", "Contains devices screen, conduits, sensor list, valve controls, command history and operation history.")

  Component(application, "Application", "Pinia Store / Facade", "Coordinates device loading, conduit linking, valve control, command history and mitigation results.")

  Component(domain, "Domain", "Domain Model", "Contains Device, Sensor, Valve, Conduit, DeviceCommand and ValveOperation frontend concepts.")

  Component(infrastructure, "Infrastructure", "API Service", "Consumes device control backend endpoints and adapts responses to frontend models.")
}

Rel(spa, presentation, "Uses device control screens", "Vue Router")

Rel(presentation, application, "Dispatches device control actions")
Rel(application, domain, "Uses device control models")
Rel(application, infrastructure, "Delegates API operations")

Rel(infrastructure, api, "Consumes device control endpoints", "HTTPS/JSON")

@enduml
