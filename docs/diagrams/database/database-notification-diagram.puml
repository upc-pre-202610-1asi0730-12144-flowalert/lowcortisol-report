@startuml
title LowCortisol Platform - Notification Database Diagram
left to right direction
hide circle
skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle

package "Notification" {
  entity "alerts" as alerts {
    PK id : uuid
    severity : varchar(40)
    status : varchar(40)
    source_type : varchar(40)
    anomaly_id : uuid
    reading_id : uuid
    site_id : uuid
    room_id : uuid
    device_group_id : uuid
    device_id : uuid
    sensor_id : uuid
    resource_type : varchar(40)
    title : varchar(160)
    description : varchar(520)
    sla_minutes_to_acknowledge : integer
    sla_minutes_to_resolve : integer
    acknowledged_at : timestamp
    resolved_at : timestamp
    closed_at : timestamp
    created_at : timestamp
    updated_at : timestamp
  }

  entity "alert_deliveries" as alert_deliveries {
    PK id : uuid
    FK alert_id : uuid
    channel_id : uuid
    channel_type : varchar(40)
    status : varchar(40)
    recipient_user_id : varchar(80)
    recipient_email : varchar(160)
    recipient_display_name : varchar(140)
    message_title : varchar(160)
    message_description : varchar(520)
    attempted_at : timestamp
    sent_at : timestamp
    failure_reason : varchar(240)
    created_at : timestamp
    updated_at : timestamp
  }

  entity "incidents" as incidents {
    PK id : uuid
    FK alert_id : uuid
    site_id : uuid
    room_id : uuid
    device_group_id : uuid
    device_id : uuid
    sensor_id : uuid
    priority : varchar(40)
    status : varchar(40)
    title : varchar(180)
    description : varchar(640)
    resolved_at : timestamp
    closed_at : timestamp
    created_at : timestamp
    updated_at : timestamp
  }

  entity "incident_actions" as incident_actions {
    PK id : uuid
    FK incident_id : uuid
    action_type : varchar(80)
    description : varchar(520)
    performed_by : varchar(140)
    performed_at : timestamp
    created_at : timestamp
    updated_at : timestamp
  }

  entity "incident_assignments" as incident_assignments {
    PK id : uuid
    FK incident_id : uuid
    assignee_id : varchar(80)
    assignee_name : varchar(140)
    assigned_at : timestamp
    is_active : boolean
    created_at : timestamp
    updated_at : timestamp
  }

  entity "notification_channels" as notification_channels {
    PK id : uuid
    name : varchar(140)
    type : varchar(40)
    is_active : boolean
    created_at : timestamp
    updated_at : timestamp
  }
}

package "External References" {
  entity "anomalies" as anomalies <<Monitoring>> {
    PK id
  }
  entity "device_commands" as device_commands <<DeviceControl>> {
    PK id
    incident_id
  }
}

alerts ||--o{ alert_deliveries : alert_id
alerts ||--o{ incidents : alert_id
incidents ||--o{ incident_actions : incident_id
incidents ||--o{ incident_assignments : incident_id
notification_channels ||..o{ alert_deliveries : channel_id
anomalies ||..o{ alerts : anomaly_id
incidents ||..o{ device_commands : incident_id

@enduml
