@startuml
title LowCortisol Platform - Monitoring Database Diagram
left to right direction
hide circle
skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle

package "Monitoring" {
  entity "consumption_readings" as consumption_readings {
    PK id : uuid
    site_id : uuid
    room_id : uuid
    device_group_id : uuid
    device_id : uuid
    sensor_id : uuid
    resource_type : varchar(40)
    value : decimal(12,2)
    unit : varchar(20)
    captured_at : timestamp
    status : varchar(40)
    created_at : timestamp
    updated_at : timestamp
  }

  entity "thresholds" as thresholds {
    PK id : uuid
    site_id : uuid
    room_id : uuid
    device_group_id : uuid
    sensor_id : uuid
    resource_type : varchar(40)
    name : varchar(120)
    operator : varchar(40)
    limit_value : decimal(12,2)
    unit : varchar(20)
    severity : varchar(40)
    is_active : boolean
    created_at : timestamp
    updated_at : timestamp
  }

  entity "anomalies" as anomalies {
    PK id : uuid
    reading_id : uuid
    threshold_id : uuid
    site_id : uuid
    room_id : uuid
    device_group_id : uuid
    device_id : uuid
    sensor_id : uuid
    resource_type : varchar(40)
    value : decimal(12,2)
    limit_value : decimal(12,2)
    unit : varchar(20)
    severity : varchar(40)
    status : varchar(40)
    description : varchar(320)
    detected_at : timestamp
    created_at : timestamp
    updated_at : timestamp
  }
}

package "External References" {
  entity "sites" as sites <<Workplace>> {
    PK id
  }
  entity "rooms" as rooms <<Workplace>> {
    PK id
  }
  entity "device_groups" as device_groups <<Workplace>> {
    PK id
  }
  entity "devices" as devices <<DeviceControl>> {
    PK id
  }
  entity "sensors" as sensors <<DeviceControl>> {
    PK id
  }
  entity "alerts" as alerts <<Notification>> {
    PK id
    anomaly_id
  }
}

sites ||..o{ consumption_readings : site_id
rooms ||..o{ consumption_readings : room_id
device_groups ||..o{ consumption_readings : device_group_id
devices ||..o{ consumption_readings : device_id
sensors ||..o{ consumption_readings : sensor_id
consumption_readings ||--o{ anomalies : reading_id
thresholds ||--o{ anomalies : threshold_id
anomalies ||..o{ alerts : anomaly_id

note right of anomalies
Critical anomalies are bridged to Notification
through the application facade, not by direct table ownership.
end note

@enduml
