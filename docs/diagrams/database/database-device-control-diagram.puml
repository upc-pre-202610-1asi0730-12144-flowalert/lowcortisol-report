@startuml
title LowCortisol Platform - Device Control Database Diagram
left to right direction
hide circle
skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle

package "Device Control" {
  entity "devices" as devices {
    PK id : uuid
    name : varchar(120)
    serial_number : varchar(80) <<unique>>
    type : varchar(40)
    status : varchar(40)
    device_group_id : uuid
    created_at : timestamp
    updated_at : timestamp
  }

  entity "sensors" as sensors {
    PK id : uuid
    FK device_id : uuid
    name : varchar(120)
    resource_type : varchar(40)
    status : varchar(40)
    last_reading_value : decimal(12,2)
    created_at : timestamp
    updated_at : timestamp
  }

  entity "valves" as valves {
    PK id : uuid
    FK device_id : uuid
    name : varchar(120)
    resource_type : varchar(40)
    status : varchar(40)
    created_at : timestamp
    updated_at : timestamp
  }

  entity "device_commands" as device_commands {
    PK id : uuid
    device_id : uuid
    valve_id : uuid
    site_id : uuid
    room_id : uuid
    device_group_id : uuid
    incident_id : uuid
    command_type : varchar(40)
    status : varchar(40)
    source : varchar(40)
    reason : varchar(240)
    requested_by : varchar(140)
    requested_at : timestamp
    executed_at : timestamp
    failed_at : timestamp
    failure_reason : varchar(320)
    created_at : timestamp
    updated_at : timestamp
  }

  entity "command_executions" as command_executions {
    PK id : uuid
    FK device_command_id : uuid
    status : varchar(40)
    started_at : timestamp
    finished_at : timestamp
    result_message : varchar(320)
    failure_reason : varchar(320)
    created_at : timestamp
    updated_at : timestamp
  }

  entity "command_audit_entries" as command_audit_entries {
    PK id : uuid
    FK device_command_id : uuid
    action : varchar(80)
    description : varchar(520)
    performed_by : varchar(140)
    performed_at : timestamp
    created_at : timestamp
    updated_at : timestamp
  }

  entity "valve_operations" as valve_operations {
    PK id : uuid
    valve_id : uuid
    device_id : uuid
    site_id : uuid
    room_id : uuid
    device_group_id : uuid
    incident_id : uuid
    resource_type : varchar(40)
    previous_status : varchar(40)
    target_status : varchar(40)
    reason : varchar(40)
    source : varchar(40)
    status : varchar(40)
    requested_at : timestamp
    completed_at : timestamp
    failed_at : timestamp
    failure_reason : varchar(320)
    created_at : timestamp
    updated_at : timestamp
  }
}

package "External References" {
  entity "device_groups" as device_groups <<Workplace>> {
    PK id
  }
  entity "incidents" as incidents <<Notification>> {
    PK id
  }
  entity "consumption_readings" as readings <<Monitoring>> {
    PK id
    device_id
    sensor_id
  }
}

device_groups ||..o{ devices : device_group_id
devices ||--o{ sensors : device_id
devices ||--o{ valves : device_id
devices ||..o{ readings : device_id
sensors ||..o{ readings : sensor_id
devices ||--o{ device_commands : device_id
valves ||--o{ device_commands : valve_id
device_commands ||--o{ command_executions : device_command_id
device_commands ||--o{ command_audit_entries : device_command_id
valves ||--o{ valve_operations : valve_id
devices ||--o{ valve_operations : device_id
incidents ||..o{ device_commands : incident_id
incidents ||..o{ valve_operations : incident_id

@enduml
