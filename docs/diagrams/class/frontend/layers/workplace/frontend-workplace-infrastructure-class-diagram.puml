package "Workplace / Infrastructure" {
  package "Infrastructure / API Services" {
    class "DeviceAssignmentsApiService" as Frontend_workplace_DeviceAssignmentsApiService <<API Service>> {
      + constructor: (
      + http: HttpClient
      + apiBaseUrl: string
      + findAllForCurrentUser() : Observable<DeviceAssignmentResponse[]>
      + findByDeviceId(deviceId: number) : Observable<DeviceAssignmentResponse[]>
    }
    class "LocationsApiService" as Frontend_workplace_LocationsApiService <<API Service>> {
      + constructor: (
      + http: HttpClient
      + apiBaseUrl: string
      + findAllForCurrentUser() : Observable<LocationResponse[]>
    }
    class "RoomsApiService" as Frontend_workplace_RoomsApiService <<API Service>> {
