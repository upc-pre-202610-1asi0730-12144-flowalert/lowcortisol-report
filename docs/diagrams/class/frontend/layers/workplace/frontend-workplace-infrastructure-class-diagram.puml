      + findByLocationId(locationId: number) : Observable<RoomResponse[]>
    }
  }
  package "Infrastructure / Assemblers" {
    class "DeviceAssignmentAssembler" as Frontend_workplace_DeviceAssignmentAssembler <<Assembler>> {
      + override: toEntity(response: DeviceAssignmentResponse): DeviceAssignment
