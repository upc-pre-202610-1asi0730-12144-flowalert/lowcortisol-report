    }
    class "LocationAssembler" as Frontend_workplace_LocationAssembler <<Assembler>> {
      + override: toEntity(response: LocationResponse): Location
      + override: toResource(entity: Location): LocationResource
    }
    class "RoomAssembler" as Frontend_workplace_RoomAssembler <<Assembler>> {
      + override: toEntity(response: RoomResponse): Room
      + override: toResource(entity: Room): RoomResource
    }
  }
  package "Infrastructure / Resources" {
    interface "DeviceAssignmentResource" as Frontend_workplace_DeviceAssignmentResource <<interface>> {
      + userId?: number
      + deviceId: number
      + locationId: number
      + roomId?: number | null
      + assignedAt: string
    }
    interface "LocationResource" as Frontend_workplace_LocationResource <<interface>> {
      + userId?: number
      + name: string
      + address: string
      + type: LocationType
      + createdAt: string
    }
    interface "RoomResource" as Frontend_workplace_RoomResource <<interface>> {
      + userId?: number
      + locationId: number
      + name: string
      + floor: string
      + createdAt: string
    }
  }
  package "Infrastructure / Responses" {
    interface "DeviceAssignmentResponse" as Frontend_workplace_DeviceAssignmentResponse <<interface>> {
      + userId: number
      + deviceId: number
      + locationId: number
      + roomId?: number | null
      + assignedAt: string
    }
    interface "LocationResponse" as Frontend_workplace_LocationResponse <<interface>> {
      + userId: number
      + name: string
      + address: string
      + type: LocationType
      + createdAt: string
    }
    interface "RoomResponse" as Frontend_workplace_RoomResponse <<interface>> {
      + userId: number
      + locationId: number
      + name: string
      + floor: string
      + createdAt: string
    }
  }
}

