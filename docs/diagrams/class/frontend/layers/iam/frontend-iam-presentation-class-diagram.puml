      + currentLocale() : string
      - t(key: string) : string
    }
    class "LoginPageComponent" as FrontendPresentation_iam_LoginPageComponent <<Component>> {
      + email
      + password
      + constructor: (
      + iamFacade: IamFacade
      - toastService: ToastService
      + onSubmit() : Promise<void>
    }
    class "PlatformPageComponent" as FrontendPresentation_iam_PlatformPageComponent <<Component>> {
      + languageOptions: DropdownOption[]
      + constructor: (
      + uiPreferences: UiPreferencesService
      - toastService: ToastService
      - translate: TranslateService
      + get: currentLanguage(): string
      + get: currentLanguageLabel(): string
      + get: currentThemeLabel(): string
      + selectLanguage(value: string) : void
      + setDarkMode(enabled: boolean) : void
      - t(key: string) : string
    }
    class "ProfilePageComponent" as FrontendPresentation_iam_ProfilePageComponent <<Component>> {
      + fullName
      + email
      + constructor: (
      + iamFacade: IamFacade
      - toastService: ToastService
      - translate: TranslateService
      + ngOnInit() : void
      + onUpdateProfile() : Promise<void>
      + hasPendingChanges() : boolean
      - t(key: string) : string
    }
    class "RecoverPasswordPageComponent" as FrontendPresentation_iam_RecoverPasswordPageComponent <<Component>> {
      + email
      + constructor: (
      + iamFacade: IamFacade
      - toastService: ToastService
      + onSubmit() : Promise<void>
    }
    class "RegisterPageComponent" as FrontendPresentation_iam_RegisterPageComponent <<Component>> {
      + fullName
      + email
      + password
      + selectedLandingPlan: LandingSelectedPlan | null
      + constructor: (
      + iamFacade: IamFacade
      + planFacade: PlanFacade
      - route: ActivatedRoute
      - router: Router
      - toastService: ToastService
      + ngOnInit() : void
      + get: passwordRequirements()
      + get: passwordIsValid(): boolean
      + get: registrationIsLoading(): boolean
      + onSubmit() : Promise<void>
      - activateSelectedLandingPlan() : Promise<void>
      - isPlanCode(value: string | null) : value is PlanCode
      - getDefaultPlanName(planCode: PlanCode) : string
    }
    class "SecurityPageComponent" as FrontendPresentation_iam_SecurityPageComponent <<Component>> {
      + constructor: (
      + iamFacade: IamFacade
      - toastService: ToastService
      - confirmDialog: ConfirmDialogService
      - translate: TranslateService
      + get: email(): string
      + sendRecovery() : Promise<void>
      + onDeleteAccount() : Promise<void>
      - t(key: string) : string
    }
  }
  package "Presentation / Routes" {
    class "IAM_ROUTES" as FrontendPresentation_iam_IAM_ROUTES <<Routes>> {
      + route: /iam/login
    }
  }
}


