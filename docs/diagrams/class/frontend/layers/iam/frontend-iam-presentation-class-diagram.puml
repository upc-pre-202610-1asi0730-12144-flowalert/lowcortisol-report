@startuml
title LowCortisol WebApp - IAM Frontend Presentation Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "IAM Presentation" {
  package "Presentation / Pages" {
    class "AccountPageComponent" as FrontendPresentation_iam_AccountPageComponent <<Component>> {
      + constructor: (
