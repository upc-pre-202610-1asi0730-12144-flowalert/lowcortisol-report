@startuml
title LowCortisol WebApp - Plan Frontend Application Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Plan / Application" {
  package "Application / Commands" {
    interface "CancelSubscriptionCommand" as Frontend_plan_CancelSubscriptionCommand <<interface>> {
      + subscriptionId: number
    }
    interface "DownloadInvoiceCommand" as Frontend_plan_DownloadInvoiceCommand <<interface>> {
      + invoiceId: number
    }
    interface "PaymentFormCommand" as Frontend_plan_PaymentFormCommand <<interface>> {
      + planCode: PlanCode
      + holderName: string
      + cardNumber: string
      + expirationDate: string
      + cvv: string
    }
  }
  package "Application / Facades and Services" {
    class "PlanFacade" as Frontend_plan_PlanFacade <<Facade>> {
      - planAssembler
      - subscriptionAssembler
      - paymentAssembler
      - invoiceAssembler
      + get: plans()
      + get: activeSubscription()
      + get: payments()
      + get: invoices()
      + get: lastPayment()
      + get: loading()
      + get: error()
      + get: hasActiveSubscription()
      + get: activePlanCode()
      + get: activePlan()
      + constructor: (
      - plansApi: PlansApiService
      - subscriptionsApi: SubscriptionsApiService
      - paymentsApi: PaymentsApiService
    }
  }
  package "Application / Stores" {
    class "PlanStore" as Frontend_plan_PlanStore <<Store>> {
      - plansSignal
      - activeSubscriptionSignal
      - paymentsSignal
      - invoicesSignal
      - lastPaymentSignal
      - loadingSignal
      - errorSignal
      + hasActiveSubscription
      + setPlans(value: Plan[]) : void
      + setActiveSubscription(value: Subscription | null) : void
      + setPayments(value: Payment[]) : void
      + setInvoices(value: Invoice[]) : void
      + setLastPayment(value: Payment | null) : void
      + prependPayment(value: Payment) : void
      + prependInvoice(value: Invoice) : void
      + setLoading(value: boolean) : void
      + setError(value: string | null) : void
      + clearMessages() : void
    }
  }
}

Frontend_plan_PlanFacade ..> Frontend_plan_PlanStore
Frontend_plan_PlanFacade ..> Frontend_plan_CancelSubscriptionCommand
Frontend_plan_PlanFacade ..> Frontend_plan_DownloadInvoiceCommand
Frontend_plan_PlanFacade ..> Frontend_plan_PaymentFormCommand


@enduml
