    }
    class "ReportFacade" as Frontend_report_ReportFacade <<Facade>> {
      - consumptionReportAssembler
      - consumptionGoalAssembler
      + get: consumptionReports()
      + get: consumptionGoals()
      + get: loading()
      + get: error()
      + get: activeGoals()
      + get: completedGoals()
      + get: failedGoals()
      + get: totalReportedWatts()
      + get: averageReportedWatts()
      + get: highestReport()
      + get: consumptionReadings()
      + constructor: (
      - consumptionReportsApi: ConsumptionReportsApiService
      - consumptionGoalsApi: ConsumptionGoalsApiService
      - planFacade: PlanFacade
      - consumptionMonitoringFacade: MonitoringFacade
    }
  }
  package "Application / Stores" {
    class "ReportStore" as Frontend_report_ReportStore <<Store>> {
      - consumptionReportsSignal
      - consumptionGoalsSignal
      - loadingSignal
      - errorSignal
      + constructor(reportSummaryService: ReportSummaryService)
      + setConsumptionReports(value: ConsumptionReport[]) : void
      + upsertConsumptionReport(value: ConsumptionReport) : void
      + removeConsumptionReport(reportId: number) : void
      + setConsumptionGoals(value: ConsumptionGoal[]) : void
      + prependConsumptionGoal(value: ConsumptionGoal) : void
      + updateConsumptionGoal(value: ConsumptionGoal) : void
      + removeConsumptionGoal(goalId: number) : void
      + setLoading(value: boolean) : void
      + setError(value: string | null) : void
    }
  }
}

