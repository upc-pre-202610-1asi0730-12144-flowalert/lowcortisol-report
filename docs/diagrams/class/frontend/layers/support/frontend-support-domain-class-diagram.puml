      + get: status(): MaintenanceTicketStatus
      + get: createdAt(): string
      + get: isPending(): boolean
    }
    class "MaintenanceTicketStatus" as Frontend_service_management_MaintenanceTicketStatus <<type>> {
      + 'PENDING' | 'SCHEDULED' | 'COMPLETED' | 'CANCELED'
    }
    class "MaintenanceTicketType" as Frontend_service_management_MaintenanceTicketType <<type>> {
      + 'INSPECTION' | 'REPAIR' | 'REPLACEMENT' | 'INSTALLATION'
    }
    class "SupportTicket" as Frontend_service_management_SupportTicket <<Entity>> {
      - _userId: number
      - _subject: string
      - _description: string
      - _priority: SupportTicketPriority
      - _status: SupportTicketStatus
      - _createdAt: string
