      + get: userId(): number
      + get: subject(): string
      + get: description(): string
      + get: priority(): SupportTicketPriority
      + get: status(): SupportTicketStatus
      + get: createdAt(): string
      + get: isOpen(): boolean
      + get: isInProgress(): boolean
      + get: isResolved(): boolean
      + get: isClosed(): boolean
      + get: isUrgent(): boolean
    }
    class "SupportTicketPriority" as Frontend_service_management_SupportTicketPriority <<type>> {
      + 'LOW' | 'MEDIUM' | 'HIGH' | 'URGENT'
    }
    class "SupportTicketStatus" as Frontend_service_management_SupportTicketStatus <<type>> {
      + 'OPEN' | 'IN_PROGRESS' | 'RESOLVED' | 'CLOSED'
    }
  }
  package "Domain / Services" {
    class "TicketPriorityService" as Frontend_service_management_TicketPriorityService <<Domain Service>> {
      - supportPriorityWeight: Record<SupportTicketPriority, number>
      - maintenanceStatusWeight: Record<MaintenanceTicketStatus, number>
      + sortSupportTickets(tickets: SupportTicket[]) : SupportTicket[]
      + sortMaintenanceTickets(tickets: MaintenanceTicket[]) : MaintenanceTicket[]
      + getSupportPriorityWeight(priority: SupportTicketPriority) : number
      + getMaintenanceStatusWeight(status: MaintenanceTicketStatus) : number
    }
  }
}

