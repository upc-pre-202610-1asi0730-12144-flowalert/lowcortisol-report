Backend_servicemanagement_MaintenanceTicketRepository ..> Backend_servicemanagement_SupportTicketCreatedEvent
Backend_servicemanagement_MaintenanceTicketRepository ..> Backend_servicemanagement_MaintenanceSchedulePolicyService
Backend_servicemanagement_MaintenanceTicketRepository ..> Backend_servicemanagement_MaintenanceTicketPolicyService
Backend_servicemanagement_MaintenanceTicketRepository ..> Backend_servicemanagement_SupportTicketPolicyService
Backend_servicemanagement_MaintenanceTicketRepository ..> Backend_servicemanagement_TicketPriorityPolicyService
Backend_servicemanagement_MaintenanceTicketRepository ..> Backend_servicemanagement_TicketStatusPolicyService
