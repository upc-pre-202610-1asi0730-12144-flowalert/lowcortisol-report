@startuml
title LowCortisol Platform - Support Backend Infrastructure Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Support / Infrastructure" {
  package "Persistence / Entity Framework Core" {
    class "SupportEntityTypeConfigurations" as Backend_support_SupportEntityTypeConfigurations <<EF Core Configuration>> {
      + Configure(SupportTicket)
      + Configure(SupportMessage)
      + Configure(SupportConversation)
      + Configure(SupportAgent)
      + Configure(KnowledgeArticle)
    }
    class "SupportTicketRepository" as Backend_support_EfSupportTicketRepository <<Repository Adapter>>
    class "SupportConversationRepository" as Backend_support_EfSupportConversationRepository <<Repository Adapter>>
    class "SupportAgentRepository" as Backend_support_EfSupportAgentRepository <<Repository Adapter>>
    class "KnowledgeArticleRepository" as Backend_support_EfKnowledgeArticleRepository <<Repository Adapter>>
  }

  package "Persistence / InMemory" {
    class "InMemorySupportTicketRepository" as Backend_support_InMemorySupportTicketRepository <<Demo Adapter>>
    class "InMemoryKnowledgeArticleRepository" as Backend_support_InMemoryKnowledgeArticleRepository <<Demo Adapter>>
  }
}

Backend_support_EfSupportTicketRepository ..|> Backend_support_ISupportTicketRepository
Backend_support_EfSupportConversationRepository ..|> Backend_support_ISupportConversationRepository
Backend_support_EfSupportAgentRepository ..|> Backend_support_ISupportAgentRepository
Backend_support_EfKnowledgeArticleRepository ..|> Backend_support_IKnowledgeArticleRepository
Backend_support_InMemorySupportTicketRepository ..|> Backend_support_ISupportTicketRepository
Backend_support_InMemoryKnowledgeArticleRepository ..|> Backend_support_IKnowledgeArticleRepository

@enduml
