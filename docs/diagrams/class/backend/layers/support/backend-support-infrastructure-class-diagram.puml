Backend_servicemanagement_JpaMaintenanceTicketRepository ..> Backend_servicemanagement_JpaSupportTicketRepository
Backend_servicemanagement_JpaMaintenanceTicketRepository ..> Backend_servicemanagement_ConsoleTicketNotificationAdapter
Backend_servicemanagement_JpaMaintenanceTicketRepository ..> Backend_servicemanagement_TicketNotificationPort

@enduml
