@startuml
title LowCortisol Platform - Report Backend Infrastructure Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Report / Infrastructure" {
  package "Infrastructure / Export" {
    class "ConsumptionReportCsvExporter" as Backend_report_ConsumptionReportCsvExporter <<Class>> {
      + export(List<ConsumptionReport> reports) : byte[]
    }
    class "ConsumptionGoalCsvExporter" as Backend_report_ConsumptionGoalCsvExporter <<Class>> {
      + export(List<ConsumptionGoal> goals) : byte[]
      - sanitize(String value) : String
    }
  }
  package "Infrastructure / EF Core" {
    class "ReportJpaTableNames" as Backend_report_ReportJpaTableNames <<Class>> {
      + CONSUMPTION_REPORTS: String
      + ENERGY_GOALS: String
      - ReportJpaTableNames()
    }
    class "ReportQueryHints" as Backend_report_ReportQueryHints <<Class>> {
      + FIND_REPORTS_BY_USER: String
      + FIND_GOALS_BY_USER: String
      + FIND_ACTIVE_GOALS: String
      - ReportQueryHints()
    }
  }
  package "Infrastructure / EF Core Repositories" {
    interface "JpaConsumptionReportRepository" as Backend_report_JpaConsumptionReportRepository <<interface>> {
    }
    interface "JpaConsumptionGoalRepository" as Backend_report_JpaConsumptionGoalRepository <<interface>> {
    }
  }
}



' Layer relationship completion: every declared type participates in this layer diagram.
Backend_report_JpaConsumptionReportRepository ..> Backend_report_ConsumptionReportCsvExporter
Backend_report_JpaConsumptionReportRepository ..> Backend_report_ConsumptionGoalCsvExporter
Backend_report_JpaConsumptionReportRepository ..> Backend_report_ReportJpaTableNames
Backend_report_JpaConsumptionReportRepository ..> Backend_report_ReportQueryHints
Backend_report_JpaConsumptionReportRepository ..> Backend_report_ConsumptionReportCsvExporter
Backend_report_JpaConsumptionReportRepository ..> Backend_report_JpaConsumptionGoalRepository

@enduml
