@startuml
title LowCortisol Platform - Report Backend Domain Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Report / Domain" {
  package "Domain / Aggregates" {
    class "ConsumptionReport" as Backend_report_ConsumptionReport <<Aggregate>> {
      - userId: Long
      - totalWatts: BigDecimal
      - averageWatts: BigDecimal
      - highestWatts: BigDecimal
      - startDate: LocalDate
      - endDate: LocalDate
    }
    class "ConsumptionGoal" as Backend_report_ConsumptionGoal <<Aggregate>> {
      - userId: Long
      - title: String
      - targetKilowattHours: BigDecimal
      - currentKilowattHours: BigDecimal
      - deadline: LocalDate
      - status: String
      - scopeType: String
      - scopeId: Long
      - scopeName: String
      - activeFrom: LocalTime
      - activeTo: LocalTime
    }
  }
  package "Domain / Commands" {
    class "CreateConsumptionReportCommand" as Backend_report_CreateConsumptionReportCommand <<record>> {
      + Long userId
      + LocalDate startDate
      + LocalDate endDate
    }
    class "CreateConsumptionGoalCommand" as Backend_report_CreateConsumptionGoalCommand <<record>> {
      + Long userId
      + String title
      + BigDecimal targetKilowattHours
      + LocalDate deadline
      + String scopeType
      + Long scopeId
      + String scopeName
      + LocalTime activeFrom
      + LocalTime activeTo
    }
    class "DeleteConsumptionGoalCommand" as Backend_report_DeleteConsumptionGoalCommand <<record>> {
      + Long userId
      + Long goalId
    }
    class "ExportReportCommand" as Backend_report_ExportReportCommand <<record>> {
      + Long userId
      + LocalDate startDate
      + LocalDate endDate
      + String format
    }
    class "GenerateConsumptionReportCommand" as Backend_report_GenerateConsumptionReportCommand <<record>> {
      + Long userId
      + LocalDate startDate
      + LocalDate endDate
    }
    class "UpdateConsumptionGoalCommand" as Backend_report_UpdateConsumptionGoalCommand <<record>> {
      + Long userId
      + Long goalId
      + String title
      + BigDecimal targetKilowattHours
      + BigDecimal currentKilowattHours
      + LocalDate deadline
      + String status
      + String scopeType
      + Long scopeId
      + String scopeName
      + LocalTime activeFrom
      + LocalTime activeTo
    }
  }
  package "Domain / Queries" {
    class "GetConsumptionReportsByUserQuery" as Backend_report_GetConsumptionReportsByUserQuery <<record>> {
      + Long userId
      + GetConsumptionReportsByUserQuery(Long userId) : record
    }
    class "GetConsumptionGoalsByUserQuery" as Backend_report_GetConsumptionGoalsByUserQuery <<record>> {
      + Long userId
      + GetConsumptionGoalsByUserQuery(Long userId) : record
    }
  }
  package "Domain / Repositories" {
    interface "ConsumptionReportRepository" as Backend_report_ConsumptionReportRepository <<interface>> {
    }
    interface "ConsumptionGoalRepository" as Backend_report_ConsumptionGoalRepository <<interface>> {
    }
  }
  package "Domain / Services" {
    class "ConsumptionReportPolicyService" as Backend_report_ConsumptionReportPolicyService <<Domain Service>> {
      + validateReportRange(LocalDate startDate, LocalDate endDate) : void
      + isValidRange(LocalDate startDate, LocalDate endDate) : boolean
    }
    class "ConsumptionGoalPolicyService" as Backend_report_ConsumptionGoalPolicyService <<Domain Service>> {
      + canCreateGoal(String title, BigDecimal targetKilowattHours, LocalDate deadline) : boolean
    }
    class "ConsumptionGoalProgressService" as Backend_report_ConsumptionGoalProgressService <<Domain Service>> {
      + calculateProgressPercentage(BigDecimal currentKilowattHours, BigDecimal targetKilowattHours) : BigDecimal
      + isCompleted(BigDecimal currentKilowattHours, BigDecimal targetKilowattHours) : boolean
    }
    class "ReportFormatPolicyService" as Backend_report_ReportFormatPolicyService <<Domain Service>> {
      + validateFormat(String format) : void
      + isCsv(String format) : boolean
      + isPdf(String format) : boolean
      + isJson(String format) : boolean
    }
    class "ReportSummaryService" as Backend_report_ReportSummaryService <<Domain Service>> {
      + calculateTotalReportedWatts(List<ConsumptionReport> reports) : BigDecimal
    }
  }
  package "Domain / Value Objects" {
    class "ConsumptionGoalTitle" as Backend_report_ConsumptionGoalTitle <<record>> {
      + String value
      + ConsumptionGoalTitle(String value) : record
    }
    class "GoalTargetWatts" as Backend_report_GoalTargetWatts <<record>> {
      + BigDecimal value
      + GoalTargetWatts(BigDecimal value) : record
    }
    class "ReportEstimatedCost" as Backend_report_ReportEstimatedCost <<record>> {
      + Money value
      + ReportEstimatedCost(Money value) : record
    }
    class "ReportPeriod" as Backend_report_ReportPeriod <<record>> {
      + LocalDate startDate
      + LocalDate endDate
      + ReportPeriod(LocalDate startDate, LocalDate endDate) : record
    }
  }
}

Backend_report_ConsumptionReportRepository ..> Backend_report_ConsumptionReport
Backend_report_ConsumptionGoalRepository ..> Backend_report_ConsumptionGoal
Backend_report_ReportSummaryService ..> Backend_report_ConsumptionReport

' Layer relationship completion: every declared type participates in this layer diagram.
Backend_report_ConsumptionReportRepository ..> Backend_report_CreateConsumptionReportCommand
Backend_report_ConsumptionReportRepository ..> Backend_report_CreateConsumptionGoalCommand
Backend_report_ConsumptionReportRepository ..> Backend_report_DeleteConsumptionGoalCommand
Backend_report_ConsumptionReportRepository ..> Backend_report_ExportReportCommand
Backend_report_ConsumptionReportRepository ..> Backend_report_GenerateConsumptionReportCommand
Backend_report_ConsumptionReportRepository ..> Backend_report_UpdateConsumptionGoalCommand
Backend_report_ConsumptionReportRepository ..> Backend_report_GetConsumptionReportsByUserQuery
Backend_report_ConsumptionReportRepository ..> Backend_report_GetConsumptionGoalsByUserQuery
Backend_report_ConsumptionReportRepository ..> Backend_report_ConsumptionReportPolicyService
Backend_report_ConsumptionReportRepository ..> Backend_report_ConsumptionGoalPolicyService
Backend_report_ConsumptionReportRepository ..> Backend_report_ConsumptionGoalProgressService
Backend_report_ConsumptionReportRepository ..> Backend_report_ReportFormatPolicyService
Backend_report_ConsumptionReportRepository ..> Backend_report_ConsumptionGoalTitle
Backend_report_ConsumptionReportRepository ..> Backend_report_GoalTargetWatts
Backend_report_ConsumptionReportRepository ..> Backend_report_ReportEstimatedCost
Backend_report_ConsumptionReportRepository ..> Backend_report_ReportPeriod

@enduml
