@startuml
title LowCortisol Platform - Plan Backend Interfaces REST Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Plan / Interfaces REST" {
  package "Controllers" {
    class "PlansController" as Backend_plan_PlansController <<REST Controller>> {
      + GetPlans(recommendedOnly, cancellationToken)
      + GetPlanById(planId, cancellationToken)
      + GetPlanSummary(userId, cancellationToken)
    }
    class "SubscriptionsController" as Backend_plan_SubscriptionsController <<REST Controller>> {
      + Subscribe(resource, cancellationToken)
      + ChangePlan(resource, cancellationToken)
      + Cancel(resource, cancellationToken)
      + GetActiveSubscription(userId, cancellationToken)
      + GetPayments(userId, cancellationToken)
      + GetServiceRequests(userId, cancellationToken)
      + ResolveServiceRequest(serviceRequestId, cancellationToken)
      + CloseServiceRequest(serviceRequestId, cancellationToken)
    }
  }

  package "Resources" {
    class "PlanResource" as Backend_plan_PlanResource <<Resource>>
    class "PlanFeatureResource" as Backend_plan_PlanFeatureResource <<Resource>>
    class "SubscriptionResource" as Backend_plan_SubscriptionResource <<Resource>>
    class "PaymentResource" as Backend_plan_PaymentResource <<Resource>>
    class "ServiceRequestResource" as Backend_plan_ServiceRequestResource <<Resource>>
    class "PlanSummaryResource" as Backend_plan_PlanSummaryResource <<Resource>>
    class "SubscribeToPlanResource" as Backend_plan_SubscribeToPlanResource <<Resource>>
    class "ChangePlanResource" as Backend_plan_ChangePlanResource <<Resource>>
    class "CancelSubscriptionResource" as Backend_plan_CancelSubscriptionResource <<Resource>>
  }

  package "Transform" {
    class "PlanAssemblers" as Backend_plan_PlanAssemblers <<Assemblers>>
    class "PlanActionResultAssembler" as Backend_plan_PlanActionResultAssembler <<Assembler>>
  }
}

Backend_plan_PlansController ..> Backend_plan_IPlanQueryService
Backend_plan_SubscriptionsController ..> Backend_plan_IPlanCommandService
Backend_plan_SubscriptionsController ..> Backend_plan_IPlanQueryService
Backend_plan_PlanAssemblers ..> Backend_plan_PlanResource
Backend_plan_PlanAssemblers ..> Backend_plan_SubscriptionResource
Backend_plan_PlanAssemblers ..> Backend_plan_PaymentResource
Backend_plan_PlanAssemblers ..> Backend_plan_ServiceRequestResource

@enduml
