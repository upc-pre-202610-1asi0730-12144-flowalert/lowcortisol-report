@startuml
title LowCortisol Platform - Plan Backend Interfaces REST Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Plan / Interfaces REST" {
  package "Interfaces / REST Assemblers" {
    class "CheckoutSubscriptionCommandFromResourceAssembler" as Backend_plan_CheckoutSubscriptionCommandFromResourceAssembler <<Assembler>> {
      - CheckoutSubscriptionCommandFromResourceAssembler()
      + toCommandFromResource(CheckoutSubscriptionResource resource, Long userId) : CheckoutSubscriptionCommand
    }
    class "InvoiceResourceFromEntityAssembler" as Backend_plan_InvoiceResourceFromEntityAssembler <<Assembler>> {
      - InvoiceResourceFromEntityAssembler()
      + toResourceFromEntity(Invoice entity) : InvoiceResource
    }
    class "PaymentResourceFromEntityAssembler" as Backend_plan_PaymentResourceFromEntityAssembler <<Assembler>> {
      - PaymentResourceFromEntityAssembler()
      + toResourceFromEntity(Payment entity) : PaymentResource
    }
    class "PlanResourceFromEntityAssembler" as Backend_plan_PlanResourceFromEntityAssembler <<Assembler>> {
      - PlanResourceFromEntityAssembler()
      + toResourceFromEntity(Plan entity) : PlanResource
    }
    class "ProcessPaymentCommandFromResourceAssembler" as Backend_plan_ProcessPaymentCommandFromResourceAssembler <<Assembler>> {
      - ProcessPaymentCommandFromResourceAssembler()
      + toCommandFromResource(ProcessPaymentResource resource, Long userId) : ProcessPaymentCommand
    }
    class "SubscribeCommandFromResourceAssembler" as Backend_plan_SubscribeCommandFromResourceAssembler <<Assembler>> {
      - SubscribeCommandFromResourceAssembler()
      + toCommandFromResource(SubscribeResource resource, Long userId) : SubscribeCommand
    }
    class "SubscriptionResourceFromEntityAssembler" as Backend_plan_SubscriptionResourceFromEntityAssembler <<Assembler>> {
      - SubscriptionResourceFromEntityAssembler()
      + toResourceFromEntity(Subscription entity) : SubscriptionResource
    }
  }
  package "Interfaces / REST Controllers" {
    class "PlanController" as Backend_plan_PlanController <<REST Controller>> {
      - planCommandService: PlanCommandService
      - planQueryService: PlanQueryService
      - currentUserProvider: CurrentUserProvider
      + getPlans() : List<PlanResource>
      + getCurrentSubscription() : SubscriptionResource
      + subscribe(SubscribeResource request) : SubscriptionResource
      + checkoutSubscription(CheckoutSubscriptionResource request) : SubscriptionResource
      + cancelSubscription() : void
      + processPayment(ProcessPaymentResource request) : PaymentResource
      + getPayments() : List<PaymentResource>
      + getInvoices() : List<InvoiceResource>
    }
  }
  package "Interfaces / REST Resources" {
    class "CheckoutSubscriptionResource" as Backend_plan_CheckoutSubscriptionResource <<record>> {
      + String planCode
      + String holderName
      + String cardNumber
      + String expirationDate
      + String cvv
    }
    class "InvoiceResource" as Backend_plan_InvoiceResource <<record>> {
      + Long id
      + Long userId
      + String invoiceNumber
      + BigDecimal totalAmount
      + String currency
      + LocalDate issuedAt
      + from(Invoice invoice) : InvoiceResource
    }
    class "PaymentResource" as Backend_plan_PaymentResource <<record>> {
      + Long id
      + Long userId
      + BigDecimal amount
      + String currency
      + String status
      + String paymentMethod
      + from(Payment payment) : PaymentResource
    }
    class "PlanResource" as Backend_plan_PlanResource <<record>> {
      + Long id
      + String code
      + String name
      + BigDecimal monthlyPrice
      + String currency
      + Integer maxDevices
      + Integer maxRoutines
      + Integer maxAlerts
      + Boolean reportExportEnabled
      + from(Plan plan) : PlanResource
    }
    class "ProcessPaymentResource" as Backend_plan_ProcessPaymentResource <<record>> {
      + Long subscriptionId
      + String holderName
      + String cardNumber
      + String expirationDate
      + String cvv
    }
    class "SubscribeResource" as Backend_plan_SubscribeResource <<record>> {
      + String planCode
    }
    class "SubscriptionResource" as Backend_plan_SubscriptionResource <<record>> {
      + Long id
      + Long userId
      + String planCode
      + String status
      + boolean active
      + LocalDate startDate
      + LocalDate nextPlanDate
      + LocalDate endDate
      + from(Subscription subscription) : SubscriptionResource
      - nextPlanDateFor(Subscription subscription) : LocalDate
    }
  }
}

Backend_plan_PlanController ..> Backend_plan_CheckoutSubscriptionCommandFromResourceAssembler
Backend_plan_PlanController ..> Backend_plan_InvoiceResourceFromEntityAssembler
Backend_plan_PlanController ..> Backend_plan_PaymentResourceFromEntityAssembler
Backend_plan_PlanController ..> Backend_plan_PlanResourceFromEntityAssembler
Backend_plan_PlanController ..> Backend_plan_ProcessPaymentCommandFromResourceAssembler
Backend_plan_PlanController ..> Backend_plan_SubscriptionResourceFromEntityAssembler
Backend_plan_CheckoutSubscriptionCommandFromResourceAssembler ..> Backend_plan_CheckoutSubscriptionResource
Backend_plan_InvoiceResourceFromEntityAssembler ..> Backend_plan_InvoiceResource
Backend_plan_PaymentResourceFromEntityAssembler ..> Backend_plan_PaymentResource
Backend_plan_PlanResourceFromEntityAssembler ..> Backend_plan_PlanResource
Backend_plan_ProcessPaymentCommandFromResourceAssembler ..> Backend_plan_ProcessPaymentResource
Backend_plan_SubscribeCommandFromResourceAssembler ..> Backend_plan_SubscribeResource
Backend_plan_SubscriptionResourceFromEntityAssembler ..> Backend_plan_SubscriptionResource


@enduml
