@startuml
title LowCortisol Platform - Plan Backend Application Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Plan / Application" {
  package "Application / Command Services" {
    interface "PlanCommandService" as Backend_plan_PlanCommandService <<interface>> {
    }
  }
  package "Application / Command Services Impl" {
    class "PlanCommandServiceImpl" as Backend_plan_PlanCommandServiceImpl <<Command Service>> {
      - planRepository: PlanRepository
      - subscriptionRepository: SubscriptionRepository
      - paymentRepository: PaymentRepository
      - invoiceRepository: InvoiceRepository
      - paymentValidationService: PaymentValidationService
      + handle(CheckoutSubscriptionCommand command) : Subscription
      + handle(CancelSubscriptionCommand command) : void
      + handle(ProcessPaymentCommand command) : Payment
      - validatePaymentDetails(CheckoutSubscriptionCommand command) : void
    }
  }
  package "Application / Query Services" {
    interface "PlanQueryService" as Backend_plan_PlanQueryService <<interface>> {
    }
  }
  package "Application / Query Services Impl" {
    class "PlanQueryServiceImpl" as Backend_plan_PlanQueryServiceImpl <<Query Service>> {
      - planRepository: PlanRepository
      - subscriptionRepository: SubscriptionRepository
      - paymentRepository: PaymentRepository
      - invoiceRepository: InvoiceRepository
      + handle(GetAllPlansQuery query) : List<Plan>
      + handle(GetCurrentSubscriptionQuery query) : Optional<Subscription>
      + handle(GetPaymentsByUserQuery query) : List<Payment>
      + handle(GetInvoicesByUserQuery query) : List<Invoice>
    }
  }
}

Backend_plan_PlanCommandServiceImpl ..> Backend_plan_PlanCommandService
Backend_plan_PlanQueryServiceImpl ..> Backend_plan_PlanQueryService


@enduml
