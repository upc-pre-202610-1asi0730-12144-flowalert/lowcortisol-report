@startuml
title LowCortisol Platform - Plan Backend Domain Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Plan / Domain" {
  package "Domain / Aggregates" {
    class "Invoice" as Backend_plan_Invoice <<Aggregate>> {
      - userId: Long
      - payment: Payment
      - invoiceNumber: String
      - totalAmount: Money
      - issuedAt: LocalDate
      + Invoice(Payment payment)
    }
    class "Payment" as Backend_plan_Payment <<Aggregate>> {
      - userId: Long
      - subscription: Subscription
      - amount: Money
      - status: PaymentStatus
      - paymentMethod: String
      - paidAt: LocalDateTime
      + Payment(ProcessPaymentCommand command, Subscription subscription)
    }
    class "Plan" as Backend_plan_Plan <<Aggregate>> {
      - code: String
      - name: String
      - monthlyPrice: Money
      - maxDevices: Integer
      - maxRoutines: Integer
      - maxAlerts: Integer
      - reportExportEnabled: Boolean
    }
    class "Subscription" as Backend_plan_Subscription <<Aggregate>> {
      - userId: Long
      - plan: Plan
      - status: SubscriptionStatus
      - startDate: LocalDate
      - endDate: LocalDate
      + Subscription(SubscribeCommand command, Plan plan)
      + isActive() : boolean
      + cancel() : void
    }
  }
  package "Domain / Commands" {
    class "CancelSubscriptionCommand" as Backend_plan_CancelSubscriptionCommand <<record>> {
      + Long userId
      + CancelSubscriptionCommand(Long userId) : record
    }
    class "CheckoutSubscriptionCommand" as Backend_plan_CheckoutSubscriptionCommand <<record>> {
      + Long userId
      + String planCode
      + String holderName
      + String cardNumber
      + String expirationDate
      + String cvv
    }
    class "ProcessPaymentCommand" as Backend_plan_ProcessPaymentCommand <<record>> {
      + Long userId
      + Long subscriptionId
    }
    class "SubscribeCommand" as Backend_plan_SubscribeCommand <<record>> {
      + Long userId
      + String planCode
    }
  }
  package "Domain / Events" {
    class "PaymentRegisteredEvent" as Backend_plan_PaymentRegisteredEvent <<record>> {
      + Long userId
      + Long paymentId
      + BigDecimal amount
      + LocalDateTime occurredOn
      + PaymentRegisteredEvent(Long userId, Long paymentId, BigDecimal amount, LocalDateTime occurredOn) : record
      + PaymentRegisteredEvent(Long userId, Long paymentId, BigDecimal amount)
    }
    class "SubscriptionActivatedEvent" as Backend_plan_SubscriptionActivatedEvent <<record>> {
      + Long userId
      + Long subscriptionId
      + String planCode
      + LocalDateTime occurredOn
      + SubscriptionActivatedEvent(Long userId, Long subscriptionId, String planCode, LocalDateTime occurredOn) : record
      + SubscriptionActivatedEvent(Long userId, Long subscriptionId, String planCode)
    }
  }
  package "Domain / Model" {
    enum "PaymentStatus" as Backend_plan_PaymentStatus <<enum>> {
      + PENDING
      + APPROVED
    }
    enum "SubscriptionStatus" as Backend_plan_SubscriptionStatus <<enum>> {
      + ACTIVE
      + CANCELLED
    }
  }
  package "Domain / Queries" {
    class "GetAllPlansQuery" as Backend_plan_GetAllPlansQuery <<record>> {
      + GetAllPlansQuery() : record
    }
    class "GetCurrentSubscriptionQuery" as Backend_plan_GetCurrentSubscriptionQuery <<record>> {
      + Long userId
      + GetCurrentSubscriptionQuery(Long userId) : record
    }
    class "GetInvoicesByUserQuery" as Backend_plan_GetInvoicesByUserQuery <<record>> {
      + Long userId
      + GetInvoicesByUserQuery(Long userId) : record
    }
    class "GetPaymentsByUserQuery" as Backend_plan_GetPaymentsByUserQuery <<record>> {
      + Long userId
      + GetPaymentsByUserQuery(Long userId) : record
    }
  }
  package "Domain / Repositories" {
    interface "InvoiceRepository" as Backend_plan_InvoiceRepository <<interface>> {
    }
    interface "PaymentRepository" as Backend_plan_PaymentRepository <<interface>> {
    }
    interface "PlanRepository" as Backend_plan_PlanRepository <<interface>> {
    }
    interface "SubscriptionRepository" as Backend_plan_SubscriptionRepository <<interface>> {
    }
  }
  package "Domain / Services" {
    class "PlanAmountPolicyService" as Backend_plan_PlanAmountPolicyService <<Domain Service>> {
      + validatePositiveAmount(Money amount) : void
      + validateCurrency(Money amount, String expectedCurrency) : void
    }
    class "InvoiceGenerationService" as Backend_plan_InvoiceGenerationService <<Domain Service>> {
      + generateInvoice(Payment payment) : Invoice
      + generateInvoiceNumber(Long paymentId) : String
    }
    class "PaymentValidationService" as Backend_plan_PaymentValidationService <<Domain Service>> {
      + isValidHolderName(String holderName) : boolean
      + isValidCardNumber(String cardNumber) : boolean
      + isValidExpirationDate(String expirationDate) : boolean
      + isValidCvv(String cvv) : boolean
    }
    class "PlanLimitPolicyService" as Backend_plan_PlanLimitPolicyService <<Domain Service>> {
      + canCreateDevice(Plan plan, int currentDeviceCount) : boolean
      + canCreateRoutine(Plan plan, int currentRoutineCount) : boolean
      + canCreateAlert(Plan plan, int currentAlertCount) : boolean
      + canExportReports(Plan plan) : boolean
    }
    class "SubscriptionPolicyService" as Backend_plan_SubscriptionPolicyService <<Domain Service>> {
      + hasActiveSubscription(Subscription subscription) : boolean
    }
  }
  package "Domain / Value Objects" {
    class "PlanPeriod" as Backend_plan_PlanPeriod <<record>> {
      + DateRange range
      + PlanPeriod(DateRange range) : record
      + PlanPeriod(LocalDate startDate, LocalDate endDate)
    }
    class "InvoiceNumber" as Backend_plan_InvoiceNumber <<record>> {
      + String value
      + InvoiceNumber(String value) : record
      - PATTERN: Pattern
    }
    class "PaymentAmount" as Backend_plan_PaymentAmount <<record>> {
      + Money money
      + PaymentAmount(Money money) : record
      + PaymentAmount(BigDecimal amount)
    }
    class "PlanName" as Backend_plan_PlanName <<record>> {
      + String value
      + PlanName(String value) : record
    }
    class "SubscriptionId" as Backend_plan_SubscriptionId <<record>> {
      + Long value
      + SubscriptionId(Long value) : record
    }
  }
}

Backend_plan_InvoiceGenerationService ..> Backend_plan_Invoice
Backend_plan_InvoiceGenerationService ..> Backend_plan_Payment
Backend_plan_InvoiceRepository ..> Backend_plan_Invoice
Backend_plan_Payment ..> Backend_plan_ProcessPaymentCommand
Backend_plan_PaymentRepository ..> Backend_plan_Payment
Backend_plan_PlanLimitPolicyService ..> Backend_plan_Plan
Backend_plan_PlanRepository ..> Backend_plan_Plan
Backend_plan_Subscription ..> Backend_plan_SubscribeCommand
Backend_plan_SubscriptionPolicyService ..> Backend_plan_Subscription
Backend_plan_SubscriptionPolicyService ..> Backend_plan_SubscriptionStatus
Backend_plan_SubscriptionRepository ..> Backend_plan_Subscription
Backend_plan_SubscriptionRepository ..> Backend_plan_SubscriptionStatus

' Layer relationship completion: every declared type participates in this layer diagram.
Backend_plan_InvoiceRepository ..> Backend_plan_CancelSubscriptionCommand
Backend_plan_InvoiceRepository ..> Backend_plan_CheckoutSubscriptionCommand
Backend_plan_InvoiceRepository ..> Backend_plan_PaymentRegisteredEvent
Backend_plan_InvoiceRepository ..> Backend_plan_SubscriptionActivatedEvent
Backend_plan_InvoiceRepository ..> Backend_plan_PaymentStatus
Backend_plan_InvoiceRepository ..> Backend_plan_GetAllPlansQuery
Backend_plan_InvoiceRepository ..> Backend_plan_GetCurrentSubscriptionQuery
Backend_plan_InvoiceRepository ..> Backend_plan_GetInvoicesByUserQuery
Backend_plan_InvoiceRepository ..> Backend_plan_GetPaymentsByUserQuery
Backend_plan_InvoiceRepository ..> Backend_plan_PlanAmountPolicyService
Backend_plan_InvoiceRepository ..> Backend_plan_PaymentValidationService
Backend_plan_InvoiceRepository ..> Backend_plan_PlanPeriod
Backend_plan_InvoiceRepository ..> Backend_plan_InvoiceNumber
Backend_plan_InvoiceRepository ..> Backend_plan_PaymentAmount
Backend_plan_InvoiceRepository ..> Backend_plan_PlanName
Backend_plan_InvoiceRepository ..> Backend_plan_SubscriptionId

@enduml
