Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_DeleteLocationCommand
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_DeleteRoomCommand
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_RemoveDeviceAssignmentCommand
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_UpdateLocationCommand
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_UpdateRoomCommand
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_DeviceAssignedToRoomEvent
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_DeviceAssignmentPolicyService
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_LocationPolicyService
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_RoomPolicyService
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_WorkplacePolicyService
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_Address
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_Capacity
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_LocationName
Backend_workplace_DeviceAssignmentRepository ..> Backend_workplace_RoomName

@enduml
