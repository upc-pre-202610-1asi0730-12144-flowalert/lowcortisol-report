@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 135
skinparam maxMessageSize 70
skinparam nodesep 35
skinparam ranksep 45
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 150
  Padding 8
}
skinparam rectangle<<BoundedContext>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  MinimumWidth 620
  Padding 12
}
hide stereotype
top to bottom direction

title LowCortisol - Frontend General Components Diagram

rectangle "<b>LowCortisol Operator</b>\n<i>[Person]</i>\n\nUses the SPA in a browser." as User #0B5593

rectangle "<b>LowCortisol Frontend Bounded Context Map</b>\n<i>[Vue 3 SPA / Frontend Container]</i>" <<BoundedContext>> {
  rectangle "<b>App Layout</b>\n<i>[Vue App Shell]</i>\n\nTopbar, navigation, language selector and router outlet." as Layout #3498DB
  rectangle "<b>App Router</b>\n<i>[Vue Router]</i>\n\nRoutes to frontend bounded contexts." as Router #3498DB

  rectangle "<b>Shared Context</b>\n<i>[Bounded Context Component]</i>\n\nSession, layout, configuration and platform services." as Shared #58A9E8
  rectangle "<b>IAM Context</b>\n<i>[Bounded Context Component]</i>\n\nAuthentication, users, profiles and access control." as IAM #58A9E8
  rectangle "<b>Plan Context</b>\n<i>[Bounded Context Component]</i>\n\nPlans, subscriptions, payments and invoices." as Plan #58A9E8

  rectangle "<b>Workplace Context</b>\n<i>[Bounded Context Component]</i>\n\nLocations, rooms and device assignments." as Workplace #58A9E8
  rectangle "<b>Device Control Context</b>\n<i>[Bounded Context Component]</i>\n\nDevices, groups, routines and operation modes." as Device #58A9E8
  rectangle "<b>Monitoring Context</b>\n<i>[Bounded Context Component]</i>\n\nReadings, sampling, statistics and dashboards." as Consumption #58A9E8

  rectangle "<b>Notification Context</b>\n<i>[Bounded Context Component]</i>\n\nAlerts, rules, preferences and evaluation." as Notification #58A9E8
  rectangle "<b>Report Context</b>\n<i>[Bounded Context Component]</i>\n\nReports, goals, exports and insights." as Report #58A9E8
  rectangle "<b>Support Context</b>\n<i>[Bounded Context Component]</i>\n\nSupport tickets, maintenance and service follow-up." as Service #58A9E8

  rectangle "<b>API Clients</b>\n<i>[Vue Infrastructure]</i>\n\nTyped services that call backend REST endpoints." as ApiClients #F39C12
}

rectangle "<b>LowCortisol Backend API</b>\n<i>[External Container]</i>\n\nASP.NET Core REST API consumed by frontend contexts." as Backend #7F8C8D

User --> Layout : uses
Layout --> Router : routed views

Router --> Shared : routes
Router --> IAM : routes
Router --> Plan : routes
Router --> Workplace : routes
Router --> Device : routes
Router --> Consumption : routes
Router --> Notification : routes
Router --> Report : routes
Router --> Service : routes

IAM --> Shared : session UI
Plan --> IAM : account context
Workplace --> IAM : user scope
Device --> Workplace : spaces
Consumption --> Device : readings
Notification --> Consumption : conditions
Report --> Plan : plan metrics
Report --> Workplace : workplace metrics
Report --> Device : operation metrics
Report --> Consumption : water and gas metrics
Service --> Device : affected devices

Shared --> ApiClients : REST services
IAM --> ApiClients : REST services
Plan --> ApiClients : REST services
Workplace --> ApiClients : REST services
Device --> ApiClients : REST services
Consumption --> ApiClients : REST services
Notification --> ApiClients : REST services
Report --> ApiClients : REST services
Service --> ApiClients : REST services
ApiClients --> Backend : JSON / HTTPS

' Compact board layout
Layout -[hidden]down- Router
Router -[hidden]down- IAM
Shared -[hidden]right- IAM
IAM -[hidden]right- Plan
Shared -[hidden]down- Workplace
IAM -[hidden]down- Device
Plan -[hidden]down- Consumption
Workplace -[hidden]right- Device
Device -[hidden]right- Consumption
Workplace -[hidden]down- Notification
Device -[hidden]down- Report
Consumption -[hidden]down- Service
Notification -[hidden]right- Report
Report -[hidden]right- Service
Report -[hidden]down- ApiClients
ApiClients -[hidden]down- Backend

legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#F39C12> infrastructure |
  |<#7F8C8D> external container |
endlegend

@enduml
